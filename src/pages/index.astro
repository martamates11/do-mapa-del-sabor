---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Spanish Flavour Map-D.O."
  description="Spanish Flavour Map-D.O. — descubre los productos españoles con Denominación de Origen, región a región."
>
  <section class="hero">
    <h1>El sabor de España,<br /><em>región a región</em></h1>
    <p class="lead">
      Un atlas pedagógico de los productos con <strong>Denominación de Origen Protegida</strong>,
      <strong>Indicación Geográfica Protegida</strong> y <strong>Especialidad Tradicional
      Garantizada</strong>. Toca una comunidad autónoma y descubre qué la hace única.
    </p>
    <div class="stats-row" id="stats-row" aria-label="Resumen de la colección"></div>
  </section>

  <section class="filters" aria-label="Filtros">
    <div class="chips" id="chips" role="group" aria-label="Filtrar por categoría"></div>
    <div class="search-wrap">
      <input id="buscador" type="search" placeholder="Busca un producto: manchego, albariño, piquillo…" aria-label="Buscar producto" autocomplete="off" />
    </div>
  </section>

  <section class="explorer">
    <div class="map-card">
      <div class="modo-toggle" id="modoToggle" role="group" aria-label="Elegir vista del mapa"></div>
      <div class="map-wrap">
        <svg id="mapa" role="group" aria-label="Mapa de España por comunidades autónomas"></svg>
        <div class="toque-mapa" id="toqueMapa" aria-hidden="true"></div>
        <div class="productos-flotantes" id="productosFlotantes" role="status" aria-hidden="true"></div>
        <div class="info-region" id="infoRegion" role="status" aria-hidden="true"></div>
      </div>
      <div class="leyenda" id="leyenda" aria-hidden="true">
        <span class="leyenda-label" id="leyendaMenos">menos productos</span>
        <span class="leyenda-ramp" aria-hidden="true"></span>
        <span class="leyenda-label" id="leyendaMas">más productos</span>
      </div>
    </div>

    <aside class="panel" id="panel" aria-live="polite"></aside>
  </section>
</Layout>

<script>
  import { MAPA_VIEWBOX, CANARIAS_INSET, CCAA_PATHS } from '../data/mapa-ccaa.js';
  import { CATEGORIAS, NOMBRES_CCAA } from '../data/productos.js';
  import { PRODUCTOS_INDEXADOS as PRODUCTOS } from '../data/productos-indexados.js';
  import { DATOS_CCAA } from '../data/datos-ccaa.js';
  import { DISTINCIONES } from '../data/restaurantes.js';
  import { RESTAURANTES_INDEXADOS as RESTAURANTES } from '../data/restaurantes-indexadas.js';
  import { TIPOS_RUTA } from '../data/rutas.js';
  import { RUTAS_INDEXADAS as RUTAS } from '../data/rutas-indexadas.js';

  const SVG_NS = 'http://www.w3.org/2000/svg';

  // Rampa secuencial (magnitud = nº de productos) sobre fondo oscuro: de tierra a azafrán.
  const RAMPA = ['#3a2418', '#6b431d', '#95621d', '#c08420', '#eab04a'];
  const SIN_PRODUCTOS = '#2a1c21';

  const estado = {
    modo: 'productos',        // 'productos' | 'restaurantes' | 'rutas'
    regionSeleccionada: null, // id de CCAA o null
    categoria: null,          // clave de grupo del modo activo o null (todas)
    busqueda: '',
  };

  const $ = (sel) => document.querySelector(sel);

  // ——— utilidades de datos (genéricas: valen para los tres modos) ———

  function itemsFiltrados() {
    const cfg = cfgActual();
    const q = estado.busqueda.trim().toLowerCase();
    return cfg.datos.filter((it) => {
      if (estado.categoria && cfg.grupoDe(it) !== estado.categoria) return false;
      if (q && !`${it.n} ${it.d}`.toLowerCase().includes(q)) return false;
      return true;
    });
  }

  function itemsDeRegion(id, lista = itemsFiltrados()) {
    return lista.filter((it) => it.ccaa.includes(id));
  }

  function colorPorCuenta(cuenta, max) {
    if (!cuenta) return SIN_PRODUCTOS;
    const t = Math.min(1, cuenta / max);
    const pos = t * (RAMPA.length - 1);
    const i = Math.min(RAMPA.length - 2, Math.floor(pos));
    return mezclar(RAMPA[i], RAMPA[i + 1], pos - i);
  }

  function mezclar(a, b, t) {
    const ca = hex(a), cb = hex(b);
    const c = ca.map((v, i) => Math.round(v + (cb[i] - v) * t));
    return `rgb(${c[0]},${c[1]},${c[2]})`;
  }

  function hex(h) {
    return [1, 3, 5].map((i) => parseInt(h.slice(i, i + 2), 16));
  }

  function escapar(s) {
    return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
  }

  function capitalizar(s) {
    return s.charAt(0).toUpperCase() + s.slice(1);
  }

  // ——— los tres modos del mapa: cada uno normaliza su propio dataset con
  // la misma forma ({ n, ccaa, d, ... }) para que el resto del script (mapa,
  // hover, panel, buscador) no necesite saber qué modo está activo ———

  const MODOS = {
    productos: {
      boton: 'Denominaciones de origen', botonCorto: 'D.O.', icono: '🧀',
      datos: PRODUCTOS,
      grupos: CATEGORIAS,
      grupoDe: (it) => it.c,
      etiqueta: (it) => it.t,
      claseBadge: (it) => `badge-${it.t}`,
      enlace: (it) => `/productos/${it.slug}`,
      externo: false,
      unidadSingular: 'producto',
      unidadPlural: 'productos',
      intro: 'Cada comunidad guarda quesos, vinos, aceites y dulces que solo pueden nacer allí. Cuanto más dorada aparece en el mapa, más tesoros reúne.',
      subtitulo: 'con sello de calidad europea',
      placeholder: 'Busca un producto: manchego, albariño, piquillo…',
    },
    restaurantes: {
      boton: 'Restaurantes con estrella', botonCorto: 'Restaurantes', icono: '⭐',
      datos: RESTAURANTES,
      grupos: DISTINCIONES,
      grupoDe: (it) => it.distincion,
      etiqueta: (it) => it.distincion,
      claseBadge: () => 'badge-neutro',
      enlace: (it) => it.enlace || null,
      externo: true,
      unidadSingular: 'restaurante',
      unidadPlural: 'restaurantes',
      intro: 'Cada comunidad esconde mesas reconocidas por la Guía Michelin. Cuanto más dorada aparece en el mapa, más distinciones reúne.',
      subtitulo: 'con distinción Michelin',
      placeholder: 'Busca un restaurante o un chef…',
    },
    rutas: {
      boton: 'Rutas gastronómicas', botonCorto: 'Rutas', icono: '🍷',
      datos: RUTAS,
      grupos: TIPOS_RUTA,
      grupoDe: (it) => it.tipo,
      etiqueta: (it) => capitalizar(it.tipo),
      claseBadge: () => 'badge-neutro',
      enlace: (it) => it.enlace || null,
      externo: true,
      unidadSingular: 'ruta',
      unidadPlural: 'rutas',
      intro: 'Cada comunidad tiene itinerarios propios para descubrir sobre el terreno el vino, el jamón, el queso o el aceite de la zona.',
      subtitulo: 'reconocida por su organismo certificador',
      placeholder: 'Busca una ruta: vino, jamón, queso…',
    },
  };

  function cfgActual() {
    return MODOS[estado.modo];
  }

  // ——— estadísticas del hero: un resumen fijo de toda la colección, igual
  // en los tres modos (no depende de qué mapa se esté viendo ni de filtros) ———

  function pintarStats() {
    const dop = PRODUCTOS.filter((p) => p.t === 'DOP').length;
    const igp = PRODUCTOS.filter((p) => p.t === 'IGP').length;
    const etg = PRODUCTOS.filter((p) => p.t === 'ETG').length;
    // en móvil, "restaurantes con estrella" y "rutas gastronómicas" no
    // caben junto a las otras tres sin partir la fila en dos o forzar el
    // scroll a un lado que deja la última tarjeta fuera de la vista
    // inicial: por debajo de 600px se muestra solo el icono del modo.
    const stats = [
      [dop, 'DOP', 'DOP'],
      [igp, 'IGP', 'IGP'],
      [etg, 'ETG', 'ETG'],
      [RESTAURANTES.length, 'restaurantes con estrella', '⭐'],
      [RUTAS.length, 'rutas gastronómicas', '🍷'],
    ];
    $('#stats-row').innerHTML = stats
      .map(
        ([n, largo, corto]) =>
          `<div class="stat"><span class="num">${n}</span><span class="lbl"><span class="texto-largo">${escapar(largo)}</span><span class="texto-corto">${escapar(corto)}</span></span></div>`
      )
      .join('');
  }

  // ——— selector de modo (productos / restaurantes / rutas) ———

  function pintarModoToggle() {
    $('#modoToggle').innerHTML = Object.entries(MODOS)
      .map(
        ([clave, m]) =>
          `<button data-modo="${clave}" aria-pressed="${estado.modo === clave}">${m.icono} <span class="texto-largo">${m.boton}</span><span class="texto-corto">${m.botonCorto}</span></button>`
      )
      .join('');
  }

  function cambiarModo(modo) {
    if (modo === estado.modo || !MODOS[modo]) return;
    estado.modo = modo;
    estado.categoria = null;
    estado.busqueda = '';
    const buscador = $('#buscador');
    buscador.value = '';
    buscador.placeholder = MODOS[modo].placeholder;
    const unidad = MODOS[modo].unidadPlural;
    $('#leyendaMenos').textContent = `menos ${unidad}`;
    $('#leyendaMas').textContent = `más ${unidad}`;
    ocultarHover();
    pintarModoToggle();
    pintarChips();
    pintarMapa();
    pintarPanel();
  }

  $('#modoToggle').addEventListener('click', (e) => {
    const btn = e.target.closest('button[data-modo]');
    if (btn) cambiarModo(btn.dataset.modo);
  });

  // ——— chips de categoría ———

  function pintarChips() {
    const cfg = cfgActual();
    const chips = [
      `<button class="chip" data-cat="" aria-pressed="${!estado.categoria}">✦ Todas</button>`,
      ...Object.entries(cfg.grupos).map(
        ([clave, g]) =>
          `<button class="chip" data-cat="${escapar(clave)}" aria-pressed="${estado.categoria === clave}">${g.icono} ${escapar(g.nombre)}</button>`
      ),
    ];
    $('#chips').innerHTML = chips.join('');
  }

  $('#chips').addEventListener('click', (e) => {
    const btn = e.target.closest('.chip');
    if (!btn) return;
    estado.categoria = btn.dataset.cat || null;
    pintarChips();
    pintarMapa();
    pintarPanel();
  });

  // En iOS reciente, `-webkit-touch-callout: none` deja de bastar para
  // evitar el menú de mantener pulsado / Live Text (fallo conocido de
  // WebKit) — pero el propio mantener pulsado sigue disparando el evento
  // `contextmenu`, así que lo interceptamos directamente en JS como
  // último recurso, sin depender de que el navegador respete la CSS.
  document.addEventListener('contextmenu', (e) => e.preventDefault());
  document.addEventListener('selectstart', (e) => e.preventDefault());

  // ——— mapa ———

  const svg = $('#mapa');
  svg.setAttribute('viewBox', MAPA_VIEWBOX);

  const capaRegiones = document.createElementNS(SVG_NS, 'g');
  svg.appendChild(capaRegiones);

  const inset = document.createElementNS(SVG_NS, 'path');
  inset.setAttribute('d', CANARIAS_INSET);
  inset.setAttribute('class', 'inset-canarias');
  svg.appendChild(inset);

  const elementosCCAA = new Map();
  const centroides = new Map();

  for (const region of CCAA_PATHS) {
    if (!region.d) continue;
    const p = document.createElementNS(SVG_NS, 'path');
    p.setAttribute('d', region.d);
    p.setAttribute('class', 'ccaa');
    p.setAttribute('tabindex', '0');
    p.setAttribute('role', 'button');
    p.dataset.id = region.id;
    if (region.centroide) {
      p.style.transformOrigin = `${region.centroide[0]}px ${region.centroide[1]}px`;
      centroides.set(region.id, region.centroide);
    }
    capaRegiones.appendChild(p);
    elementosCCAA.set(region.id, p);
  }

  function pintarMapa() {
    const cfg = cfgActual();
    const lista = itemsFiltrados();
    const cuentas = new Map();
    let max = 1;
    for (const [id] of elementosCCAA) {
      const n = itemsDeRegion(id, lista).length;
      cuentas.set(id, n);
      if (n > max) max = n;
    }
    for (const [id, el] of elementosCCAA) {
      el.setAttribute('fill', colorPorCuenta(cuentas.get(id), max));
      const nombre = NOMBRES_CCAA[id] || id;
      el.setAttribute('aria-label', `${nombre}: ${cuentas.get(id)} ${cfg.unidadPlural}`);
      el.classList.toggle('seleccionada', estado.regionSeleccionada === id);
    }
    svg.classList.toggle('mapa-atenuado', !!estado.regionSeleccionada);
  }

  // ——— hover enriquecido: región más grande, tarjeta de datos al instante,
  // productos con un pequeño retraso (solo si el ratón se queda quieto) ———
  const mapWrap = $('.map-wrap');
  const panelEl = $('#panel');
  const productosFlotantes = $('#productosFlotantes');
  const infoRegion = $('#infoRegion');
  const RETRASO_PRODUCTOS = 900; // ms sin mover el ratón antes de abrir la tarjeta
  let regionHover = null;
  let temporizadorProductos = null;

  function activarRegionHover(id) {
    const el = elementosCCAA.get(id);
    if (!el) return;
    el.classList.add('en-hover');
    capaRegiones.appendChild(el); // trae la región al frente sobre sus vecinas

    const nombre = NOMBRES_CCAA[id] || id;
    const datos = DATOS_CCAA[id];
    if (datos) {
      infoRegion.innerHTML = `
        <h3>${escapar(nombre)}</h3>
        <dl>
          <div><dt>Extensión</dt><dd>${datos.extension.toLocaleString('es-ES')} km²</dd></div>
          <div><dt>Altitud</dt><dd>${datos.altitud} m</dd></div>
          <div><dt>Clima</dt><dd>${escapar(datos.clima)}</dd></div>
          <div><dt>Temp. máx.</dt><dd>${datos.tempMax} °C</dd></div>
          <div><dt>Temp. mín.</dt><dd>${datos.tempMin} °C</dd></div>
        </dl>`;
      infoRegion.classList.add('visible');
    }
  }

  function mostrarGrupoFlotante(id) {
    const cfg = cfgActual();
    const nombre = NOMBRES_CCAA[id] || id;
    const items = itemsDeRegion(id);

    const porGrupo = new Map();
    for (const it of items) {
      const g = cfg.grupoDe(it);
      porGrupo.set(g, (porGrupo.get(g) || 0) + 1);
    }
    const grupos = [...porGrupo.entries()].sort((a, b) => b[1] - a[1]);

    productosFlotantes.innerHTML = `
      <span class="pf-nombre">${escapar(nombre)}</span>
      ${
        grupos.length
          ? `<ul>${grupos
              .map(
                ([clave, n]) =>
                  `<li><span>${cfg.grupos[clave]?.icono || ''} ${escapar(cfg.grupos[clave]?.nombre || clave)}</span><span class="pf-cont">${n}</span></li>`
              )
              .join('')}</ul>`
          : `<p class="pf-vacio">Sin ${cfg.unidadPlural} en la muestra actual</p>`
      }`;
    productosFlotantes.classList.add('visible');
  }

  function ocultarHover() {
    if (temporizadorProductos) {
      clearTimeout(temporizadorProductos);
      temporizadorProductos = null;
    }
    if (regionHover) elementosCCAA.get(regionHover)?.classList.remove('en-hover');
    regionHover = null;
    productosFlotantes.classList.remove('visible');
    infoRegion.classList.remove('visible');
  }

  svg.addEventListener('pointermove', (e) => {
    // el hover (agrandar región, tarjetas flotantes) solo tiene sentido con
    // ratón/trackpad: con el dedo no hay forma de "salir" de la región sin
    // tocar otro sitio, así que se quedaría visualmente pegada tras tocar.
    if (e.pointerType === 'touch') return;

    const el = e.target.closest('.ccaa');
    const id = el ? el.dataset.id : null;

    if (id !== regionHover) {
      if (regionHover) elementosCCAA.get(regionHover)?.classList.remove('en-hover');
      productosFlotantes.classList.remove('visible');
      regionHover = id;
      if (id) activarRegionHover(id);
      else infoRegion.classList.remove('visible');
    }

    // cualquier movimiento (entrar en la región o desplazarse dentro de ella)
    // reinicia la cuenta atrás: la tarjeta de productos solo se abre si el
    // ratón se queda quieto sobre la misma región.
    if (temporizadorProductos) clearTimeout(temporizadorProductos);
    if (id) {
      temporizadorProductos = setTimeout(() => {
        if (regionHover === id) mostrarGrupoFlotante(id);
      }, RETRASO_PRODUCTOS);
    }
  });

  svg.addEventListener('pointerleave', ocultarHover);

  function activarRegion(id, { desplazar = true } = {}) {
    estado.regionSeleccionada = estado.regionSeleccionada === id ? null : id;
    pintarMapa();
    pintarPanel();
    if (desplazar && window.matchMedia('(max-width: 940px)').matches && estado.regionSeleccionada) {
      $('#panel').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }

  svg.addEventListener('click', (e) => {
    const el = e.target.closest('.ccaa');
    if (el) activarRegion(el.dataset.id);
  });

  svg.addEventListener('keydown', (e) => {
    if (e.key !== 'Enter' && e.key !== ' ') return;
    const el = e.target.closest('.ccaa');
    if (el) {
      e.preventDefault();
      activarRegion(el.dataset.id);
    }
  });

  // ——— capa táctil: en pantallas táctiles, el toque no llega directamente
  // al SVG. Así el dedo nunca posa sobre contenido de texto/imagen que iOS
  // pueda ofrecerse a seleccionar o analizar (causa del recuadro azul que
  // ni la CSS ni el bloqueo de `contextmenu` consiguieron evitar) ———
  const toqueMapa = $('#toqueMapa');
  // El iPad (y algún Android en modo "escritorio") puede reportar
  // pointer:fine/hover:hover aunque no haya ratón — por eso no basta con
  // matchMedia solo; se comprueba también la capacidad táctil real.
  const esTactil =
    window.matchMedia('(hover: none) and (pointer: coarse)').matches ||
    'ontouchstart' in window ||
    navigator.maxTouchPoints > 0;

  function cerrarTarjetasTactiles() {
    if (regionHover) elementosCCAA.get(regionHover)?.classList.remove('en-hover');
    regionHover = null;
    productosFlotantes.classList.remove('visible');
    infoRegion.classList.remove('visible');
    if (estado.regionSeleccionada) {
      estado.regionSeleccionada = null;
      pintarMapa();
      pintarPanel();
    }
  }

  if (esTactil) {
    toqueMapa.classList.add('activa');
    let inicioToque = null;

    toqueMapa.addEventListener('touchstart', (e) => {
      const t = e.touches[0];
      inicioToque = { x: t.clientX, y: t.clientY };
    }, { passive: true });

    toqueMapa.addEventListener('touchend', (e) => {
      if (!inicioToque) return;
      const t = e.changedTouches[0];
      const dx = Math.abs(t.clientX - inicioToque.x);
      const dy = Math.abs(t.clientY - inicioToque.y);
      inicioToque = null;
      if (dx > 10 || dy > 10) return; // fue un arrastre/scroll, no un toque

      toqueMapa.style.pointerEvents = 'none';
      const el = document.elementFromPoint(t.clientX, t.clientY);
      toqueMapa.style.pointerEvents = '';
      const region = el ? el.closest('.ccaa') : null;
      if (!region) {
        // toque dentro del mapa pero fuera de cualquier región: cierra las
        // tarjetas y vuelve al mapa para elegir otra comunidad.
        cerrarTarjetasTactiles();
        return;
      }

      const id = region.dataset.id;
      // Un toque es una acción deliberada (no hay "de paso" como con el
      // ratón): se abren las dos tarjetas al instante, sin el retraso que
      // sí tiene sentido para el hover de escritorio.
      if (regionHover && regionHover !== id) elementosCCAA.get(regionHover)?.classList.remove('en-hover');
      activarRegionHover(id);
      regionHover = id; // el ratón lo actualiza en pointermove; el toque no pasaba por ahí y dejaba "cerrar tarjetas al tocar fuera" sin efecto
      mostrarGrupoFlotante(id);
      // sin desplazar la pantalla: si no, el salto automático al panel
      // taparía las tarjetas que se acaban de abrir.
      activarRegion(id, { desplazar: false });
    });

    // Toque fuera del mapa por completo (cabecera, filtros...): también
    // cierra las tarjetas si había alguna región activa. El panel se
    // excluye a propósito: es donde vive la lista de la propia región
    // seleccionada (productos/restaurantes/rutas con su enlace, el botón
    // "volver"...), así que tocar dentro de él es seguir explorando esa
    // misma región, no una señal de "quiero abandonarla". Si no se
    // excluyera, cerrarTarjetasTactiles() repinta el panel entero en
    // touchend, y el enlace que se acababa de tocar quedaba destruido
    // antes de que el navegador llegase a procesar la navegación.
    //
    // Igual que en el toque dentro del mapa, hace falta distinguir un
    // toque real de un arrastre: cerrar ya en touchstart hacía que el
    // simple gesto de empezar a hacer scroll con el dedo apoyado fuera
    // del mapa cerrase la selección antes de que diera tiempo a
    // desplazarse.
    let inicioToqueFuera = null;

    document.addEventListener('touchstart', (e) => {
      if (!regionHover || mapWrap.contains(e.target) || panelEl.contains(e.target)) {
        inicioToqueFuera = null;
        return;
      }
      const t = e.touches[0];
      inicioToqueFuera = { x: t.clientX, y: t.clientY };
    }, { passive: true });

    document.addEventListener('touchend', (e) => {
      if (!inicioToqueFuera) return;
      const t = e.changedTouches[0];
      const dx = Math.abs(t.clientX - inicioToqueFuera.x);
      const dy = Math.abs(t.clientY - inicioToqueFuera.y);
      inicioToqueFuera = null;
      if (dx > 10 || dy > 10) return; // fue scroll/arrastre, no un toque deliberado
      cerrarTarjetasTactiles();
    }, { passive: true });
  }

  // ——— panel lateral ———

  function pintarPanel() {
    const cfg = cfgActual();
    const panel = $('#panel');
    const q = estado.busqueda.trim();

    // búsqueda global activa y sin región: resultados en toda España
    if (q && !estado.regionSeleccionada) {
      const resultados = itemsFiltrados();
      panel.innerHTML = `
        <div class="panel-region">
          <h2>Resultados</h2>
          <p class="panel-sub">${resultados.length} ${resultados.length === 1 ? cfg.unidadSingular : cfg.unidadPlural} para «${escapar(q)}» en toda España</p>
          ${resultados.length ? listaItems(resultados, true) : '<p class="sin-datos">Nada por aquí… prueba con otro nombre.</p>'}
        </div>`;
      return;
    }

    if (!estado.regionSeleccionada) {
      const lista = itemsFiltrados();
      const ranking = [...elementosCCAA.keys()]
        .map((id) => [id, itemsDeRegion(id, lista).length])
        .filter(([, n]) => n > 0)
        .sort((a, b) => b[1] - a[1])
        .slice(0, 8);
      panel.innerHTML = `
        <div class="panel-vacio">
          <h2>Elige una región del mapa</h2>
          <p>${cfg.intro}</p>
          <p class="pista">O empieza por las que más reúnen:</p>
          <ol class="ranking">
            ${ranking
              .map(
                ([id, n]) =>
                  `<li><button data-region="${id}"><span>${escapar(NOMBRES_CCAA[id] || id)}</span><span class="r-num">${n}</span></button></li>`
              )
              .join('')}
          </ol>
        </div>`;
      return;
    }

    const id = estado.regionSeleccionada;
    const nombre = NOMBRES_CCAA[id] || id;
    const items = itemsDeRegion(id);

    panel.innerHTML = `
      <div class="panel-region">
        <button class="volver" data-volver>← Ver toda España</button>
        <h2>${escapar(nombre)}</h2>
        <p class="panel-sub">${
          items.length
            ? `${items.length} ${items.length === 1 ? cfg.unidadSingular : cfg.unidadPlural} ${cfg.subtitulo}`
            : 'Sin registros con los filtros actuales'
        }</p>
        ${items.length ? listaItems(items) : `<p class="sin-datos">Prueba a quitar filtros o revisa otra categoría.</p>`}
      </div>`;
  }

  function listaItems(items, mostrarRegion = false) {
    const cfg = cfgActual();
    const porGrupo = new Map();
    for (const it of items) {
      const g = cfg.grupoDe(it);
      if (!porGrupo.has(g)) porGrupo.set(g, []);
      porGrupo.get(g).push(it);
    }
    return [...porGrupo.entries()]
      .sort((a, b) => b[1].length - a[1].length)
      .map(
        ([clave, lista]) => `
        <div class="grupo-cat">
          <h3>${cfg.grupos[clave]?.icono || ''} ${escapar(cfg.grupos[clave]?.nombre || clave)}</h3>
          ${lista
            .map((it) => {
              const region = mostrarRegion
                ? `<span class="resultado-region">${escapar(NOMBRES_CCAA[it.ccaa[0]] || '')}${it.ccaa.length > 1 ? ' +' + (it.ccaa.length - 1) : ''}</span>`
                : '';
              const etiqueta = cfg.etiqueta(it);
              const badge = etiqueta ? `<span class="badge ${cfg.claseBadge(it)}">${escapar(etiqueta)}</span>` : '';
              const contenido = `<span class="p-nombre">${escapar(it.n)}</span>${region}${badge}`;
              const href = cfg.enlace(it);
              return href
                ? `<a class="producto" href="${href}"${cfg.externo ? ' target="_blank" rel="noopener"' : ''}>${contenido}</a>`
                : `<div class="producto producto-sin-enlace">${contenido}</div>`;
            })
            .join('')}
        </div>`
      )
      .join('');
  }

  $('#panel').addEventListener('click', (e) => {
    const volver = e.target.closest('[data-volver]');
    if (volver) {
      estado.regionSeleccionada = null;
      pintarMapa();
      pintarPanel();
      return;
    }
    const regionBtn = e.target.closest('[data-region]');
    if (regionBtn) {
      activarRegion(regionBtn.dataset.region);
      return;
    }
  });

  // ——— buscador ———

  $('#buscador').addEventListener('input', (e) => {
    estado.busqueda = e.target.value;
    if (estado.busqueda.trim()) estado.regionSeleccionada = null;
    pintarMapa();
    pintarPanel();
  });

  // ——— arranque ———

  pintarModoToggle();
  pintarStats();
  pintarChips();
  pintarMapa();
  pintarPanel();
</script>
